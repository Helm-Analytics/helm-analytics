    {
      "id": "22",
      "name": "Draft Contextual Reply",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "position": [-550, 900],
      "parameters": {
        "text": "A user on Twitter just posted this:\n\"{{$json.text}}\"\n\nWrite a helpful, empathetic, non-spammy reply from 'Helm Analytics' (A privacy-first, ultra-fast website intelligence platform built on ClickHouse. Features: Cookieless, Session Replay, Traffic Quality Score to block bots, Firewall). Answer their question or validate their pain point *first*, then subtly mention how a tool like Helm helps. Keep it under 280 characters.",
        "promptType": "define"
      },
      "typeVersion": 1.7
    },
