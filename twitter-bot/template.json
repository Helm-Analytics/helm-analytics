    {
      "id": "14",
      "name": "Filter OSS/Analytics",
      "type": "n8n-nodes-base.function",
      "position": [-750, 500],
      "parameters": {
        "functionCode": "return items.filter(i => {\n  const title = (i.json.title || '').toLowerCase();\n  return title.includes('open source') || title.includes('analytics');\n});"
      },
      "typeVersion": 1
    },
    {
