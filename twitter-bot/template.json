    {
      "id": "2",
      "name": "Google Gemini",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "position": [-992, 224],
      "parameters": { "options": { "topP": 0.8 } },
      "credentials": { "googlePalmApi": { "id": "HguTQIWY1C9qT3eH", "name": "Google Gemini Api account" } },
