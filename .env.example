# Helm Analytics - Environment Configuration
# Copy this file to .env and customize the values

# Database Configuration
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change_this_secure_password_123
POSTGRES_DB=sentinel

# ClickHouse Configuration
CLICKHOUSE_USER=sentinel
CLICKHOUSE_PASSWORD=change_this_secure_password_456
CLICKHOUSE_DATABASE=sentinel

# Gemini AI API Key (Optional - for AI insights)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret (Change this!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Deployment Mode
DEPLOYMENT_MODE=community

# SMTP Configuration (Optional - for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@helm.io
