# Helm Analytics Configuration

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================
# Options: "community" (self-hosted) or "cloud" (managed)
DEPLOYMENT_MODE=community

# =============================================================================
# LICENSE (Self-Hosted Pro/Enterprise)
# =============================================================================
# Leave LICENSE_KEY blank for Community Edition (free, open-source)
# Add your Pro/Enterprise license key to unlock premium features
# License validation happens LOCALLY with embedded public key (no server needed)
LICENSE_KEY=

# =============================================================================
# ADMIN API (Cloud Only)
# =============================================================================
# Admin API key for manual subscription management
# Generate a secure random string and keep it secret!
# Used for: POST /api/admin/subscription
ADMIN_API_KEY=your-secure-admin-api-key-here

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://helm:changeme@localhost:5432/helm
CLICKHOUSE_URL=clickhouse://localhost:9000

# =============================================================================
# AI FEATURES
# =============================================================================
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Rate limits
AI_RATE_LIMIT_FREE=5          # Community: 5 AI requests per day
AI_RATE_LIMIT_PRO=unlimited   # Pro/Cloud: unlimited

# =============================================================================
# BILLING (Cloud Only)
# =============================================================================
# Stripe (Global payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Paystack (African payments)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# =============================================================================
# SERVER
# =============================================================================
PORT=6060
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# SECURITY
# =============================================================================
SESSION_SECRET=change-this-to-a-random-string
JWT_SECRET=another-random-string

# GeoIP Database (for country detection)
GEOIP_DB_PATH=./GeoLite2-Country.mmdb
GEOIP_ASN_PATH=./GeoLite2-ASN.mmdb

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================
# Email (for reports)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@helm.io

# Slack (for alerts)
SLACK_WEBHOOK_URL=

# Google Search Console (Pro/Cloud feature)
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
