# --- Helm Analytics Environment Configuration ---

# Registry Images
BACKEND_IMAGE=danielowenllm/helm-analytics-backend:latest
FRONTEND_IMAGE=danielowenllm/helm-analytics-frontend:latest

# Frontend Settings
VITE_API_URL=https://analytics.yourdomain.com

# Backend Settings
DATABASE_URL=postgres://sentinel:password@db:5432/sentinel?sslmode=disable
GEMINI_API_KEY=your_gemini_api_key_here
DEPLOYMENT_MODE=community # Options: community, cloud

# ClickHouse Settings
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=sentinel
CLICKHOUSE_USER=sentinel
CLICKHOUSE_PASSWORD=password

# Postgres Settings (Matched with root DB service)
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=password
POSTGRES_DB=sentinel

# Tracking Script (Point this to your public domain)
PUBLIC_TRACKER_URL=https://analytics.yourdomain.com
